# Local Claude Code settings (machine-specific; never commit)
.claude/settings.local.json

# SQLite runtime artifacts (the sqlite backend creates these, e.g. rerun.db)
*.db
*.db-shm
*.db-wal

# ...but the committed v0.1 golden journal fixtures are the deliberate exception
# (self-contained .db, no -wal/-shm; see golden_test.go).
!testdata/golden/**/*.db

# macOS
.DS_Store
